# Copy this to .env and fill in your own values
# .env is gitignored - never commit real credentials

# ── Confluent Cloud (Kafka) ──────────────────────────────────
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxxx.us-east-1.aws.confluent.cloud:9092
CONFLUENT_API_KEY=
CONFLUENT_API_SECRET=

# ── Snowflake ────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=           # e.g. xy12345.us-east-1
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FRAUD_DB
SNOWFLAKE_WAREHOUSE=FRAUD_WH
SNOWFLAKE_ROLE=SYSADMIN

# ── dbt ──────────────────────────────────────────────────────
DBT_PROFILES_DIR=./config

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_HOME=~/airflow
SLACK_WEBHOOK_URL=           # for fraud alerts
